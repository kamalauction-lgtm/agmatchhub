# --- App URLs (no hard-coded domains anywhere in code; final domain TBD) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
AUTH_CALLBACK_URL=http://localhost:3000/auth/callback
REQUEST_LINK_BASE_URL=http://localhost:3000/r
CLIENT_PRESENTATION_BASE_URL=http://localhost:3000/p

# --- Brand fallbacks (DB brand_settings overrides win at runtime) ---
NEXT_PUBLIC_APP_NAME="IQI AG MatchHub"
NEXT_PUBLIC_APP_SHORT_NAME="MatchHub"
NEXT_PUBLIC_APP_TAGLINE="One Requirement. Multiple Opportunities. Controlled Collaboration."

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# --- Security ---
# 32+ random bytes, base64. Signs client-presentation session cookies.
TOKEN_SIGNING_SECRET=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Cloudflare (CI/deploy only) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Email ---
EMAIL_FROM_DOMAIN=
